pipeline {
    agent any
    
    environment {
        PATH = "/usr/local/bin:/usr/bin:/bin:/opt/homebrew/bin"
        DOCKER_IMAGE = 'abhishekzod19/sample-app:latest'
        DOCKER_USER = 'abhishekzod19'  // Non-secret username
        DOCKER_REPO = 'sample-app'      // Repository name
        DOCKER_TAG = 'latest'            // Tag
        GCP_PROJECT = 'my-cloud-native-project-490312'
        GKE_CLUSTER = 'cicd-gke-cluster'
        GKE_ZONE = 'europe-west4-a'
        KUBECONFIG = '/Users/abhishekzod/.kube/config'
        DOCKER_HUB_PASSWORD = credentials('docker-hub-credentials')
    }
    
    stages {
        stage('Checkout') {
            steps {
                git branch: 'main', 
                    url: 'https://github.com/Abhishekzod19/Cloud-Native-CI-CD-Deployment-Platform.git',
                    credentialsId: 'github-credentials'
            }
        }
        
        stage('Build Docker Image') {
            steps {
                script {
                    dir('app') {
                        sh 'docker logout'
                        // Build with explicit username
                        sh "docker build -t ${DOCKER_USER}/${DOCKER_REPO}:${DOCKER_TAG} ."
                    }
                }
            }
        }
        
        stage('Push to Docker Hub') {
            steps {
                script {
                    sh """
                        echo "=== DOCKER PUSH STAGE ==="
                        echo "Logging in to Docker Hub..."
                        # Use explicit non-secret username
                        echo "${DOCKER_HUB_PASSWORD}" | docker login -u ${DOCKER_USER} --password-stdin
                        
                        echo "Pushing image: ${DOCKER_USER}/${DOCKER_REPO}:${DOCKER_TAG}"
                        docker push ${DOCKER_USER}/${DOCKER_REPO}:${DOCKER_TAG}
                        
                        echo "Logging out..."
                        docker logout
                        echo "=== PUSH COMPLETE ==="
                    """
                }
            }
        }
        
        stage('Deploy to GKE') {
            steps {
                script {
                    sh """
                        gcloud container clusters get-credentials ${GKE_CLUSTER} \
                            --zone ${GKE_ZONE} --project ${GCP_PROJECT}
                        
                        # Update deployment with correct image
                        sed -i '' 's|\\${DOCKER_IMAGE}|${DOCKER_USER}/${DOCKER_REPO}:${DOCKER_TAG}|g' kubernetes/deployment.yaml
                        
                        kubectl apply -f kubernetes/deployment.yaml
                        kubectl apply -f kubernetes/service.yaml
                        
                        kubectl rollout status deployment/sample-app
                    """
                }
            }
        }
        
        stage('Get Application URL') {
            steps {
                script {
                    sh """
                        echo "Application deployed! Getting service info..."
                        kubectl get service sample-app-service
                    """
                }
            }
        }
    }
    
    post {
        always {
            cleanWs()
        }
        success {
            echo '🎉 Pipeline completed successfully! Your app is live on GKE!'
        }
        failure {
            echo 'Pipeline failed! Check the logs for details.'
        }
    }
}