pipeline {
    agent any
    
    environment {
        PATH = "/usr/local/bin:/usr/bin:/bin:/opt/homebrew/bin"
        DOCKER_IMAGE = 'abhishek19/sample-app:latest'
        GCP_PROJECT = 'my-cloud-native-project-490312'
        GKE_CLUSTER = 'cicd-gke-cluster'
        GKE_ZONE = 'europe-west4-a'
        KUBECONFIG = '/Users/abhishekzod/.kube/config'
    }
    
    stages {
        stage('Checkout') {
            steps {
                git branch: 'main', 
                    url: 'https://github.com/Abhishekzod19/Cloud-Native-CI-CD-Deployment-Platform.git',
                    credentialsId: 'github-credentials'
            }
        }
        
        stage('Build Docker Image') {
            steps {
                script {
                    dir('app') {
                        docker.build("${DOCKER_IMAGE}")
                    }
                }
            }
        }
        
        stage('Push to Docker Hub') {
            steps {
                script {
                    withEnv(['PATH=/usr/local/bin:/usr/bin:/bin']) {
                        docker.withRegistry('', 'docker-hub-credentials') {
                            docker.image("${DOCKER_IMAGE}").push()
                        }
                    }
                }
            }
        }
        
        stage('Deploy to GKE') {
            steps {
                script {
                    sh """
                        gcloud container clusters get-credentials ${GKE_CLUSTER} \
                            --zone ${GKE_ZONE} --project ${GCP_PROJECT}
                        
                        sed -i '' 's|\\${DOCKER_IMAGE}|${DOCKER_IMAGE}|g' kubernetes/deployment.yaml
                        
                        kubectl apply -f kubernetes/deployment.yaml
                        kubectl apply -f kubernetes/service.yaml
                        
                        kubectl rollout status deployment/sample-app
                    """
                }
            }
        }
        
        stage('Get Application URL') {
            steps {
                script {
                    sh """
                        echo "Application deployed! Getting service info..."
                        kubectl get service sample-app-service
                    """
                }
            }
        }
    }
    
    post {
        always {
            cleanWs()
        }
        success {
            echo 'Pipeline completed successfully!'
        }
    }
}